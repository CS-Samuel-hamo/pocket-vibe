# Pocket Vibe v1 backend configuration

# Backend network
HOST=0.0.0.0
PORT=8000
# Leave blank to let Pocket Vibe infer your LAN address for the phone link.
VITE_FRONTEND_URL=
AUTO_OPEN_PAIRING_PAGE=true

# Optional remote/public entrypoints.
# Use these when the phone is not on the same LAN, or when desktop/mobile VPN changes local routing.
# PUBLIC_FRONTEND_URL is the URL the phone opens.
# PUBLIC_API_BASE_URL is the backend HTTP base URL reachable from the phone.
# PUBLIC_BACKEND_WS_URL is the backend websocket URL reachable from the phone.
# Generate these with: .\scripts\prepare_remote_access.ps1
PUBLIC_FRONTEND_URL=
PUBLIC_API_BASE_URL=
PUBLIC_BACKEND_WS_URL=

# Pairing and workspace
# Leave POCKET_VIBE_TOKEN empty to generate a temporary token at startup.
POCKET_VIBE_TOKEN=
TARGET_DIR=.

# Runtime safeguards
MAX_FILE_READ_BYTES=10485760
E2EE_ENABLED=true
LOG_LEVEL=INFO
